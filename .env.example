# 三才量化 — 环境变量配置
# 复制此文件为 .env 并填入你的密钥

# Tavily AI 搜索引擎 (https://tavily.com)
TAVILY_API_KEY=

# AI 摘要服务 (DeepSeek 或 Anthropic Claude)
SUMMARIZER_API_KEY=

# API 鉴权密钥 (不设置则不启用认证)
SANCAI_API_KEY=

# 飞书机器人 Webhook (实时监控推送 https://open.feishu.cn)
FEISHU_WEBHOOK_URL=

# Firecrawl 财经新闻抓取 (https://firecrawl.dev)
FIRECRAWL_API_KEY=
